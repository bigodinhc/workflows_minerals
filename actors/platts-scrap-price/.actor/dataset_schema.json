{
    "actorSpecification": 1,
    "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
            "type": {
                "type": "string",
                "description": "Run outcome indicator: success or error.",
                "enum": ["success", "error"],
                "nullable": true,
                "example": "success"
            },
            "source": {
                "type": "string",
                "description": "Data source identifier.",
                "nullable": true,
                "example": "Platts Iron Ore Price Assessments"
            },
            "message": {
                "type": "string",
                "description": "Human-readable message (populated on error or credential-missing runs).",
                "nullable": true,
                "example": "Username e password são obrigatórios"
            },
            "error": {
                "type": "string",
                "description": "Error message when type is 'error'.",
                "nullable": true,
                "example": "Login falhou"
            },
            "timestamp": {
                "type": "string",
                "description": "ISO 8601 timestamp of the error event.",
                "nullable": true,
                "example": "2026-01-15T12:00:00.000Z"
            },
            "summary": {
                "type": "object",
                "description": "Aggregate metrics for the extraction.",
                "properties": {
                    "totalExtracted": {
                        "type": "number",
                        "description": "Total number of symbols extracted.",
                        "nullable": true,
                        "example": 166
                    },
                    "withDescription": {
                        "type": "number",
                        "description": "Number of symbols that had a description.",
                        "nullable": true,
                        "example": 166
                    },
                    "withPrice": {
                        "type": "number",
                        "description": "Number of symbols that had a non-empty price.",
                        "nullable": true,
                        "example": 142
                    },
                    "breakdown": {
                        "type": "object",
                        "description": "Count of symbols per Platts category prefix.",
                        "properties": {
                            "IO": { "type": "number", "description": "IO-prefixed iron ore symbols.", "nullable": true, "example": 48 },
                            "TSI": { "type": "number", "description": "TSI-prefixed index symbols.", "nullable": true, "example": 12 },
                            "AAQ": { "type": "number", "description": "AAQ-prefixed assessment symbols.", "nullable": true, "example": 8 },
                            "SB": { "type": "number", "description": "SB-prefixed symbols.", "nullable": true, "example": 15 },
                            "CA": { "type": "number", "description": "CA-prefixed symbols.", "nullable": true, "example": 10 },
                            "SI": { "type": "number", "description": "SI-prefixed symbols.", "nullable": true, "example": 9 },
                            "AH": { "type": "number", "description": "AH-prefixed symbols.", "nullable": true, "example": 6 },
                            "APO": { "type": "number", "description": "AP-prefixed (APO group) symbols.", "nullable": true, "example": 4 },
                            "TS": { "type": "number", "description": "TS-prefixed symbols.", "nullable": true, "example": 7 },
                            "Others": { "type": "number", "description": "Symbols that did not match any known prefix.", "nullable": true, "example": 47 }
                        },
                        "required": [],
                        "additionalProperties": true,
                        "nullable": true,
                        "example": { "IO": 48, "TSI": 12, "Others": 47 }
                    },
                    "extractedAt": {
                        "type": "string",
                        "description": "ISO 8601 timestamp when extraction finished.",
                        "nullable": true,
                        "example": "2026-01-15T12:00:00.000Z"
                    }
                },
                "required": [],
                "additionalProperties": true,
                "nullable": true,
                "example": {
                    "totalExtracted": 166,
                    "withDescription": 166,
                    "withPrice": 142,
                    "extractedAt": "2026-01-15T12:00:00.000Z"
                }
            },
            "data": {
                "type": "array",
                "description": "Flat array of all extracted symbols.",
                "items": {
                    "type": "object",
                    "properties": {
                        "symbol": { "type": "string", "description": "Platts symbol code.", "nullable": true, "example": "IODBZ00" },
                        "description": { "type": "string", "description": "Human-readable description of the assessment.", "nullable": true, "example": "Iron Ore Fines 62% Fe CFR China" },
                        "price": { "type": "string", "description": "Assessed price as shown in the grid (string to preserve formatting).", "nullable": true, "example": "102.55" },
                        "chg": { "type": "string", "description": "Absolute change vs previous assessment.", "nullable": true, "example": "+0.85" },
                        "chgPercent": { "type": "string", "description": "Percent change vs previous assessment.", "nullable": true, "example": "+0.84%" },
                        "assessedDate": { "type": "string", "description": "Assessment date as shown in the grid.", "nullable": true, "example": "15/01/2026" },
                        "currUom": { "type": "string", "description": "Currency and unit of measure.", "nullable": true, "example": "USD/dmt" },
                        "assessmentType": { "type": "string", "description": "Type of assessment (e.g., Spot, Forward).", "nullable": true, "example": "Spot" },
                        "subCommodity": { "type": "string", "description": "Sub-commodity classification.", "nullable": true, "example": "Iron Ore Fines" }
                    },
                    "required": [],
                    "additionalProperties": true
                },
                "nullable": true,
                "example": [
                    {
                        "symbol": "IODBZ00",
                        "description": "Iron Ore Fines 62% Fe CFR China",
                        "price": "102.55",
                        "chg": "+0.85",
                        "chgPercent": "+0.84%",
                        "assessedDate": "15/01/2026",
                        "currUom": "USD/dmt",
                        "assessmentType": "Spot",
                        "subCommodity": "Iron Ore Fines"
                    }
                ]
            },
            "categorized": {
                "type": "object",
                "description": "Same symbols grouped by category prefix.",
                "properties": {
                    "IO": { "type": "array", "description": "IO-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "TSI": { "type": "array", "description": "TSI-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "AAQ": { "type": "array", "description": "AAQ-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "SB": { "type": "array", "description": "SB-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "CA": { "type": "array", "description": "CA-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "SI": { "type": "array", "description": "SI-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "AH": { "type": "array", "description": "AH-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "APO": { "type": "array", "description": "AP-prefixed (APO group) symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "TS": { "type": "array", "description": "TS-prefixed symbols.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] },
                    "Others": { "type": "array", "description": "Symbols not matching any known prefix.", "items": { "type": "object", "additionalProperties": true }, "nullable": true, "example": [] }
                },
                "required": [],
                "additionalProperties": true,
                "nullable": true,
                "example": { "IO": [], "TSI": [], "Others": [] }
            }
        },
        "required": [],
        "additionalProperties": true
    },
    "views": {
        "overview": {
            "title": "Overview",
            "description": "Run-level summary of iron ore price assessments.",
            "transformation": {
                "fields": [
                    "type",
                    "source",
                    "summary.totalExtracted",
                    "summary.withPrice",
                    "summary.breakdown.IO",
                    "summary.breakdown.TSI",
                    "summary.breakdown.AAQ",
                    "summary.extractedAt"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "type": { "label": "Status", "format": "text" },
                    "source": { "label": "Source", "format": "text" },
                    "summary.totalExtracted": { "label": "Total Symbols", "format": "number" },
                    "summary.withPrice": { "label": "With Price", "format": "number" },
                    "summary.breakdown.IO": { "label": "IO", "format": "number" },
                    "summary.breakdown.TSI": { "label": "TSI", "format": "number" },
                    "summary.breakdown.AAQ": { "label": "AAQ", "format": "number" },
                    "summary.extractedAt": { "label": "Extracted At", "format": "date" }
                }
            }
        }
    }
}
